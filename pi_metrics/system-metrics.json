{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB data source",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "CPU Temperatur (aktuell)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"raspberry-pi\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cpu_temperature\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) / 1000.0 }))\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Auslastung (aktuell)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"raspberry-pi\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cpu\")\n  |> filter(fn: (r) => r._field == \"usage_idle\")\n  |> filter(fn: (r) => r.cpu == \"cpu-total\")\n  |> map(fn: (r) => ({ r with _value: 100.0 - r._value }))\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 3,
      "title": "Disk Auslastung /",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"raspberry-pi\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"disk\")\n  |> filter(fn: (r) => r._field == \"used_percent\")\n  |> filter(fn: (r) => r.path == \"/\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 4,
      "title": "Disk Belegung",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [{ "id": "displayName", "value": "Belegt" }]
          },
          {
            "matcher": { "id": "byName", "options": "free" },
            "properties": [
              { "id": "displayName", "value": "Frei" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"raspberry-pi\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"disk\")\n  |> filter(fn: (r) => r._field == \"used\" or r._field == \"free\")\n  |> filter(fn: (r) => r.path == \"/\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Temperatur",
      "description": "Temperatur des Raspberry Pi SoC über Zeit",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "value" },
            "properties": [{ "id": "displayName", "value": "Temperatur (°C)" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"raspberry-pi\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cpu_temperature\")\n  |> filter(fn: (r) => r._field == \"value\")\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) / 1000.0 }))\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 6,
      "title": "CPU Auslastung",
      "description": "CPU-Nutzung aufgeteilt nach user/system/iowait",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "min": 0,
          "max": 100
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "usage_user" },
            "properties": [
              { "id": "displayName", "value": "User" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "usage_system" },
            "properties": [
              { "id": "displayName", "value": "System" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "usage_iowait" },
            "properties": [
              { "id": "displayName", "value": "I/O Wait" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"raspberry-pi\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cpu\")\n  |> filter(fn: (r) => r._field == \"usage_user\" or r._field == \"usage_system\" or r._field == \"usage_iowait\")\n  |> filter(fn: (r) => r.cpu == \"cpu-total\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 7,
      "title": "Disk Auslastung über Zeit",
      "description": "Belegter und freier Speicher auf /",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [
              { "id": "displayName", "value": "Belegt" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "free" },
            "properties": [
              { "id": "displayName", "value": "Frei" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"raspberry-pi\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"disk\")\n  |> filter(fn: (r) => r._field == \"used\" or r._field == \"free\")\n  |> filter(fn: (r) => r.path == \"/\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["system", "raspberry-pi", "waerme-pi"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "waerme-pi System",
  "uid": "waerme-pi-system",
  "version": 1
}