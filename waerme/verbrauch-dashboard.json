          "query": "from(bucket: \"waerme\")\n  |> range(start: -365d)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"energie_kwh\")\n  |> aggregateWindow(every: 1h, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"year\")"
        }
      ]
    },
    {
      "id": 5,
      "title": "Täglicher Verbrauch",
      "description": "Wärmeenergie pro Tag in kWh",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "_value" },
            "properties": [{ "id": "displayName", "value": "Verbrauch (kWh)" }]
          }
        ]
      },
      "options": {
        "xTickLabelRotation": -45,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "barWidth": 0.7
      },
      "targets": [
