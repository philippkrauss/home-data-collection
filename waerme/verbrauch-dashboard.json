          "query": "from(bucket: \"waerme\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"energie_kwh\")\n  |> aggregateWindow(every: 1h, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"month\")"
        }
      ]
    },
    {
      "id": 4,
      "title": "Verbrauch dieses Jahr",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
