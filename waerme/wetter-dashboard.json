{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB data source",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Temperatur",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "super-light-blue", "value": 0 },
              { "color": "green", "value": 10 },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 28 },
              { "color": "red", "value": 35 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"temperature_c\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 2,
      "title": "Gefühlt",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "super-light-blue", "value": 0 },
              { "color": "green", "value": 10 },
              { "color": "yellow", "value": 20 },
              { "color": "orange", "value": 28 },
              { "color": "red", "value": 35 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"apparent_temperature_c\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 3,
      "title": "Luftfeuchtigkeit",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 30 },
              { "color": "yellow", "value": 70 },
              { "color": "blue", "value": 85 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"humidity_pct\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 4,
      "title": "Luftdruck",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "pressurehpa",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"pressure_hpa\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 5,
      "title": "Wind",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "velocitykmh",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "wind_speed_kmh" },
            "properties": [{ "id": "displayName", "value": "Geschwindigkeit" }]
          },
          {
            "matcher": { "id": "byName", "options": "wind_gusts_kmh" },
            "properties": [{ "id": "displayName", "value": "Böen" }]
          }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value", "orientation": "horizontal" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"wind_speed_kmh\" or r._field == \"wind_gusts_kmh\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 6,
      "title": "Wolkendecke",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 0 },
              { "color": "super-light-blue", "value": 50 },
              { "color": "blue", "value": 80 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"cloud_cover_pct\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 7,
      "title": "Niederschlag letzte Stunde",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthmm",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "super-light-blue", "value": 0.1 },
              { "color": "blue", "value": 5 },
              { "color": "dark-blue", "value": 20 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "rain_mm" }, "properties": [{ "id": "displayName", "value": "Regen (mm)" }] },
          { "matcher": { "id": "byName", "options": "snowfall_cm" }, "properties": [{ "id": "displayName", "value": "Schnee (cm)" }, { "id": "unit", "value": "lengthcm" }] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value", "orientation": "horizontal" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"rain_mm\" or r._field == \"snowfall_cm\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 8,
      "title": "UV Index",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 8 },
              { "color": "purple", "value": 11 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"uv_index\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 9,
      "title": "Temperaturverlauf",
      "description": "Temperatur und gefühlte Temperatur über Zeit",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "temperature_c" },
            "properties": [
              { "id": "displayName", "value": "Temperatur" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "apparent_temperature_c" },
            "properties": [
              { "id": "displayName", "value": "Gefühlt" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "dew_point_c" },
            "properties": [
              { "id": "displayName", "value": "Taupunkt" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"temperature_c\" or r._field == \"apparent_temperature_c\" or r._field == \"dew_point_c\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 10,
      "title": "Wind & Böen",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "velocitykmh",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "wind_speed_kmh" },
            "properties": [
              { "id": "displayName", "value": "Windgeschwindigkeit" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "wind_gusts_kmh" },
            "properties": [
              { "id": "displayName", "value": "Böen" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "dash": [6, 6], "fill": "dash" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"wind_speed_kmh\" or r._field == \"wind_gusts_kmh\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 11,
      "title": "Luftfeuchtigkeit & Luftdruck",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "humidity_pct" },
            "properties": [
              { "id": "displayName", "value": "Luftfeuchtigkeit (%)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pressure_hpa" },
            "properties": [
              { "id": "displayName", "value": "Luftdruck (hPa)" },
              { "id": "unit", "value": "pressurehpa" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"humidity_pct\" or r._field == \"pressure_hpa\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 12,
      "title": "Niederschlag",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthmm",
          "custom": { "lineWidth": 0, "fillOpacity": 80, "spanNulls": false, "drawStyle": "bars" },
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rain_mm" },
            "properties": [
              { "id": "displayName", "value": "Regen (mm)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "snowfall_cm" },
            "properties": [
              { "id": "displayName", "value": "Schnee (cm)" },
              { "id": "unit", "value": "lengthcm" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "super-light-blue" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"rain_mm\" or r._field == \"snowfall_cm\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 13,
      "title": "Wolkendecke & Sonnenschein",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cloud_cover_pct" },
            "properties": [
              { "id": "displayName", "value": "Wolkendecke (%)" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "super-light-blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "sunshine_duration_s" },
            "properties": [
              { "id": "displayName", "value": "Sonnenschein (s/h)" },
              { "id": "unit", "value": "s" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"weather\")\n  |> filter(fn: (r) => r._field == \"cloud_cover_pct\" or r._field == \"sunshine_duration_s\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    }
  ],
  "refresh": "1h",
  "schemaVersion": 38,
  "tags": ["wetter", "dettenhausen", "open-meteo"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Wetter Dettenhausen",
  "uid": "wetter-dettenhausen",
  "version": 1
}