{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB data source for heat meter metrics",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "influxdb",
      "name": "InfluxDB",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Wärmemenge gesamt",
      "description": "Kumulierte Energie seit Inbetriebnahme",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"energie_kwh\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 2,
      "title": "Aktuelle Leistung",
      "description": "Momentane Wärmeleistung in kW",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"leistung_kw\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 3,
      "title": "Vorlauf / Rücklauf",
      "description": "Aktuelle Vor- und Rücklauftemperatur",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 8, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "vorlauf_c" },
            "properties": [
              { "id": "displayName", "value": "Vorlauf" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ruecklauf_c" },
            "properties": [
              { "id": "displayName", "value": "Rücklauf" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"vorlauf_c\" or r._field == \"ruecklauf_c\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 4,
      "title": "Volumen gesamt",
      "description": "Kumulierter Durchfluss seit Inbetriebnahme",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 13, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "m3",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"volumen_m3\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 5,
      "title": "Betriebsstunden",
      "description": "Gesamte Betriebsstunden",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 17, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value",
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"betriebsstunden_h\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 6,
      "title": "Wärmeleistung",
      "description": "Momentane Wärmeleistung über Zeit",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false
          },
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "leistung_kw" },
            "properties": [{ "id": "displayName", "value": "Leistung (kW)" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"leistung_kw\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 7,
      "title": "Vorlauf- & Rücklauftemperatur",
      "description": "Temperaturdifferenz zeigt Wärmeabnahme",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "vorlauf_c" },
            "properties": [
              { "id": "displayName", "value": "Vorlauf" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ruecklauf_c" },
            "properties": [
              { "id": "displayName", "value": "Rücklauf" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"vorlauf_c\" or r._field == \"ruecklauf_c\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 8,
      "title": "Durchfluss",
      "description": "Momentaner Volumenstrom in m³/h",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "m3/h",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false
          },
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "teal" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "durchfluss_m3ph" },
            "properties": [{ "id": "displayName", "value": "Durchfluss (m³/h)" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"durchfluss_m3ph\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 9,
      "title": "Tagesverbrauch (Energie)",
      "description": "Täglich verbrauchte Wärmeenergie in kWh",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 80,
            "spanNulls": false,
            "drawStyle": "bars",
            "barAlignment": 0
          },
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "energie_kwh" },
            "properties": [{ "id": "displayName", "value": "Energie (kWh)" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"waerme\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"uh50\")\n  |> filter(fn: (r) => r._field == \"energie_kwh\")\n  |> aggregateWindow(every: 1d, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"daily\")"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["waerme", "uh50", "heizung"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Wärme (UH50)",
  "uid": "waerme-uh50",
  "version": 1
}