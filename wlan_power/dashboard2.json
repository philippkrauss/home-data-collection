{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB data source",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
        "definition": "from(bucket: \"tuya-strom\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> keep(columns: [\"device\"])\n  |> distinct(column: \"device\")",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "device",
        "options": [],
        "query": "from(bucket: \"tuya-strom\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> keep(columns: [\"device\"])\n  |> distinct(column: \"device\")",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Gerät"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Verbrauch heute",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: today())\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"${device}\")\n  |> filter(fn: (r) => r._field == \"energy_kwh\")\n  |> aggregateWindow(every: 1h, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"today\")"
        }
      ]
    },
    {
      "id": 2,
      "title": "Verbrauch diese Woche",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"${device}\")\n  |> filter(fn: (r) => r._field == \"energy_kwh\")\n  |> aggregateWindow(every: 1h, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"week\")"
        }
      ]
    },
    {
      "id": 3,
      "title": "Verbrauch diesen Monat",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"${device}\")\n  |> filter(fn: (r) => r._field == \"energy_kwh\")\n  |> aggregateWindow(every: 1h, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"month\")"
        }
      ]
    },
    {
      "id": 4,
      "title": "Täglicher Verbrauch",
      "description": "Energieverbrauch pro Tag für das gewählte Gerät",
      "type": "barchart",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "fillOpacity": 80, "lineWidth": 1 },
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "_value" },
            "properties": [{ "id": "displayName", "value": "Verbrauch (kWh)" }]
          }
        ]
      },
      "options": {
        "xTickLabelRotation": -45,
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "barWidth": 0.7
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"${device}\")\n  |> filter(fn: (r) => r._field == \"energy_kwh\")\n  |> aggregateWindow(every: 1d, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"daily\")"
        }
      ]
    }
  ],
  "refresh": "1h",
  "schemaVersion": 38,
  "tags": ["tuya", "strom", "verbrauch"],
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Smart Plugs Verbrauch",
  "uid": "tuya-verbrauch",
  "version": 1
}