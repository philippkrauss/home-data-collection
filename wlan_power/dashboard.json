{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "InfluxDB data source",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Aus", "color": "blue" }, "1": { "text": "An", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"switch\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 2,
      "title": "Aktuelle Leistung",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1500 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"power_w\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 3,
      "title": "Spannung",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"voltage_v\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 4,
      "title": "Stromstärke",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "mamp",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"current_ma\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 5,
      "title": "Gesamtverbrauch",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"energy_kwh\")\n  |> last()\n  |> yield(name: \"last\")"
        }
      ]
    },
    {
      "id": 6,
      "title": "Leistung über Zeit",
      "description": "Aktuelle Watt-Aufnahme der Kaffeemaschine",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "decimals": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": false },
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "power_w" }, "properties": [{ "id": "displayName", "value": "Leistung (W)" }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"power_w\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 7,
      "title": "Spannung über Zeit",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "decimals": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "voltage_v" }, "properties": [{ "id": "displayName", "value": "Spannung (V)" }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"voltage_v\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 8,
      "title": "Stromstärke über Zeit",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "mamp",
          "decimals": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "current_ma" }, "properties": [{ "id": "displayName", "value": "Stromstärke (mA)" }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"current_ma\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    },
    {
      "id": 9,
      "title": "Kumulierter Verbrauch",
      "description": "Gesamtenergie seit Inbetriebnahme",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "energy_kwh" }, "properties": [{ "id": "displayName", "value": "Verbrauch (kWh)" }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"tuya-strom\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"smart_plug\")\n  |> filter(fn: (r) => r.device == \"Kaffeemaschine\")\n  |> filter(fn: (r) => r._field == \"energy_kwh\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["tuya", "strom", "kaffeemaschine"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kaffeemaschine",
  "uid": "tuya-kaffeemaschine",
  "version": 1
}