            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"fritzbox\")\n  |> range(start: today())\n  |> filter(fn: (r) => r._measurement == \"internet\")\n  |> filter(fn: (r) => r._field == \"total_bytes_down\" or r._field == \"total_bytes_up\")\n  |> aggregateWindow(every: 1h, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"today\")",
          "refId": "A"
