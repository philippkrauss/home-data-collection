            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"fritzbox\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"internet\")\n  |> filter(fn: (r) => r._field == \"total_bytes_down\" or r._field == \"total_bytes_up\")\n  |> aggregateWindow(every: 1mo, fn: max, createEmpty: false)\n  |> difference(nonNegative: true)\n  |> yield(name: \"monthly\")",
          "refId": "A"
        }
      ],
      "title": "Übertragung pro Monat",
      "type": "barchart"
    }
  ],
